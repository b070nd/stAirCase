set -euo pipefail

VERSION="1.1.0"

# ── Color helpers (all write to stderr) ────────────────────────────────────────
_R=''; _G=''; _Y=''; _C=''; _B=''; _D=''; _Z=''
if [[ -z "${NO_COLOR:-}" ]]; then
  _R=$'\033[0;31m'; _G=$'\033[0;32m'; _Y=$'\033[1;33m'
  _C=$'\033[0;36m'; _B=$'\033[1m';    _D=$'\033[0;90m'; _Z=$'\033[0m'
fi
_info() { printf "  %s→%s  %s\n" "$_C" "$_Z" "$*" >&2; }
_ok()   { printf "  %s✔%s  %s\n" "$_G" "$_Z" "$*" >&2; }
_warn() { printf "  %s⚠%s  %s\n" "$_Y" "$_Z" "$*" >&2; }
_err()  { printf "  %s✖%s  %s\n" "$_R" "$_Z" "$*" >&2; }

DRY_RUN="${DRY_RUN:-}"

_ws_root() {
  if [[ -n "${STAIRCASE_DIR:-}" ]]; then
    [[ -d "$STAIRCASE_DIR/.staircase" ]] && { printf '%s' "$STAIRCASE_DIR"; return 0; }
    return 1
  fi
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    [[ -d "$dir/.staircase" ]] && { printf '%s' "$dir"; return 0; }
    dir="$(dirname "$dir")"
  done
  return 1
}
_require_ws() { local ws; if ! ws="$(_ws_root)"; then _err "no workspace found — run: staircase init"; exit 1; fi; printf '%s' "$ws"; }
_require_jq() { if ! command -v jq &>/dev/null; then _err "jq is required — brew install jq"; exit 1; fi; }
_tmp_dir() { printf '%s' "${STAIRCASE_TMP_DIR:-$1/.staircase/tmp}"; }
_hooks_dir() { local ws="$1"; if [[ -n "${STAIRCASE_HOOKS_DIR:-}" ]]; then printf '%s' "$STAIRCASE_HOOKS_DIR"; else printf '%s' "$ws/$(jq -r '.hooks_dir // "hooks.d"' "$ws/.staircase/config.json" 2>/dev/null)"; fi; }
_runner() { local ws="$1" v="${2:-}" p="${3:-}" f="${4:-}"; [[ -n "$f" ]] && { printf '%s' "$f"; return; }; [[ -n "${STAIRCASE_RUNNER:-}" ]] && { printf '%s' "$STAIRCASE_RUNNER"; return; }; if [[ -n "$v" && -n "$p" ]]; then local pr; pr="$(jq -r '.runner // empty' "$ws/$v/$p/.staircase/config.json" 2>/dev/null)"; [[ -n "$pr" ]] && { printf '%s' "$pr"; return; }; fi; local wr; wr="$(jq -r '.runner // empty' "$ws/.staircase/config.json" 2>/dev/null)"; [[ -n "$wr" ]] && { printf '%s' "$wr"; return; }; printf '%s' "ralph-tui"; }
_file_mtime() { local f="$1" r; if r="$(date -r "$f" "+%Y-%m-%d %H:%M:%S" 2>/dev/null)"; then printf '%s' "$r"; elif r="$(stat -c "%y" "$f" 2>/dev/null)"; then printf '%s' "${r%%.*}"; else printf '%s' "-"; fi; }
_atomic_write() { local dest="$1" td="$2"; mkdir -p "$td"; local t; t="$(mktemp "$td/sc.XXXXXX")"; cat > "$t"; mv "$t" "$dest"; }
_parse_vp() { local vp="$1"; if [[ "$vp" != */* ]]; then _err "expected vendor/project, got: '$vp'"; exit 1; fi; SC_VENDOR="${vp%%/*}"; SC_PROJECT="${vp#*/}"; if [[ -z "$SC_VENDOR" || -z "$SC_PROJECT" || "$SC_PROJECT" == */* ]]; then _err "expected vendor/project, got: '$vp'"; exit 1; fi; }
_require_project() { local ws="$1" v="$2" p="$3"; local e; e="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p] // empty' "$ws/.staircase/manifest.json")"; if [[ -z "$e" ]]; then _err "'${v}/${p}' not registered — run: staircase project add ${v}/${p}"; exit 1; fi; }
_source_path() { local ws="$1" v="$2" p="$3"; jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].source // empty' "$ws/.staircase/manifest.json" 2>/dev/null || true; }

cmd_init() { local ws_name=""; while [[ $# -gt 0 ]]; do case "$1" in --name) ws_name="${2:-}"; shift 2 ;; *) shift ;; esac; done; [[ -z "$ws_name" ]] && ws_name="$(basename "$PWD")"; local ws="$PWD"; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] create .staircase/"; [[ -f "$ws/.staircase/config.json" ]] && _ok "already initialized (no changes)"; return 0; fi; mkdir -p "$ws/.staircase/tmp"; if [[ ! -f "$ws/.staircase/config.json" ]]; then _require_jq; jq -n --arg n "$ws_name" '{version:"1.0",name:$n,runner:"ralph-tui",hooks_dir:"hooks.d",defaults:{context_schema:{stories:[],files:[],gitDiff:""}}}' > "$ws/.staircase/config.json"; printf '{"version":"1.0","vendors":{}}\n' > "$ws/.staircase/manifest.json"; _ok "initialized workspace '${ws_name}'"; else _ok "already initialized"; fi; }

cmd_config() { local ws; ws="$(_require_ws)"; _require_jq; local key="${1:-}" val="${2:-}"; local cfg="$ws/.staircase/config.json"; if [[ "$key" == "--list" ]]; then printf "%s%-16s  %-20s  %s%s\n" "$_B" "KEY" "VALUE" "SOURCE" "$_Z" >&2; printf "%-16s  %-20s  %s\n" "----------------" "--------------------" "--------" >&2; local wr; wr="$(jq -r '.runner // "ralph-tui"' "$cfg")"; local rs="config"; [[ -n "${STAIRCASE_RUNNER:-}" ]] && { wr="$STAIRCASE_RUNNER"; rs="${_G}env${_Z}"; }; printf "%-16s  %-20s  %b\n" "runner" "$wr" "$rs" >&2; local hd; hd="$(jq -r '.hooks_dir // "hooks.d"' "$cfg")"; local hs="config"; [[ -n "${STAIRCASE_HOOKS_DIR:-}" ]] && { hd="$STAIRCASE_HOOKS_DIR"; hs="${_G}env${_Z}"; }; printf "%-16s  %-20s  %b\n" "hooks_dir" "$hd" "$hs" >&2; local td=".staircase/tmp" ts="default"; [[ -n "${STAIRCASE_TMP_DIR:-}" ]] && { td="$STAIRCASE_TMP_DIR"; ts="${_G}env${_Z}"; }; printf "%-16s  %-20s  %b\n" "tmp_dir" "$td" "$ts" >&2; printf "%-16s  %-20s  %s\n" "name" "$(jq -r '.name // "-"' "$cfg")" "config" >&2; return 0; fi; if [[ -z "$key" ]]; then jq '.' "$cfg"; return 0; fi; if [[ -z "$val" ]]; then jq -r --arg k "$key" '.[$k] // empty' "$cfg"; return 0; fi; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] config.$key = $val"; return 0; fi; local td; td="$(_tmp_dir "$ws")"; jq --arg k "$key" --arg v "$val" '.[$k] = $v' "$cfg" | _atomic_write "$cfg" "$td"; _ok "config.$key = $val"; }

cmd_vendor_add() { local v="${1:-}"; [[ -z "$v" ]] && { _err "Usage: staircase vendor add <vendor>"; exit 1; }; local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json"; local e; e="$(jq -r --arg v "$v" '.vendors[$v] // empty' "$m")"; [[ -n "$e" ]] && { _err "vendor '${v}' already exists"; exit 1; }; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] add vendor '${v}'"; return 0; fi; mkdir -p "$ws/$v"; local td; td="$(_tmp_dir "$ws")"; local d; d="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; jq --arg v "$v" --arg d "$d" '.vendors[$v]={"registered_at":$d,"projects":{}}' "$m" | _atomic_write "$m" "$td"; _ok "added vendor '${v}'"; }
cmd_vendor_remove() { local v="${1:-}"; [[ -z "$v" ]] && { _err "Usage: staircase vendor remove <vendor>"; exit 1; }; local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json"; local pc; pc="$(jq -r --arg v "$v" '.vendors[$v].projects // {} | keys | length' "$m" 2>/dev/null)"; [[ "${pc:-0}" -gt 0 ]] && { _err "vendor '${v}' has projects — remove them first"; exit 1; }; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] remove vendor '${v}'"; return 0; fi; local td; td="$(_tmp_dir "$ws")"; jq --arg v "$v" 'del(.vendors[$v])' "$m" | _atomic_write "$m" "$td"; _ok "removed vendor '${v}'"; }
cmd_vendor_list() { local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json"; local vs; vs="$(jq -r '.vendors | keys[]' "$m" 2>/dev/null || true)"; [[ -z "$vs" ]] && { _info "no vendors"; return 0; }; while IFS= read -r v; do local pc; pc="$(jq -r --arg v "$v" '.vendors[$v].projects|keys|length' "$m")"; printf "  %s%s%s  %s(%s project%s)%s\n" "$_B" "$v" "$_Z" "$_D" "$pc" "$([[ "$pc" -eq 1 ]] && echo "" || echo "s")" "$_Z" >&2; done <<< "$vs"; }
cmd_vendor() { local s="${1:-}"; shift || true; case "$s" in add) cmd_vendor_add "$@" ;; remove) cmd_vendor_remove "$@" ;; list|ls) cmd_vendor_list "$@" ;; *) _err "Usage: staircase vendor <add|remove|list>"; exit 1 ;; esac; }

cmd_project_add() { local vp="${1:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase project add <vendor/project>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json" td; td="$(_tmp_dir "$ws")"; local d; d="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; local e; e="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p] // empty' "$m" 2>/dev/null)"; [[ -n "$e" ]] && { _err "'${SC_VENDOR}/${SC_PROJECT}' already exists"; exit 1; }; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] add project '${SC_VENDOR}/${SC_PROJECT}'"; return 0; fi; local ve; ve="$(jq -r --arg v "$SC_VENDOR" '.vendors[$v] // empty' "$m")"; if [[ -z "$ve" ]]; then mkdir -p "$ws/$SC_VENDOR"; jq --arg v "$SC_VENDOR" --arg d "$d" '.vendors[$v]={"registered_at":$d,"projects":{}}' "$m" | _atomic_write "$m" "$td"; _ok "auto-created vendor '${SC_VENDOR}'"; fi; local pd="$ws/$SC_VENDOR/$SC_PROJECT"; mkdir -p "$pd/.staircase/active" "$pd/.staircase/tasks"; jq -n --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg d "$d" '{vendor:$v,project:$p,components:[],runner:null,created_at:$d}' > "$pd/.staircase/config.json"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg d "$d" '.vendors[$v].projects[$p]={"registered_at":$d,"components":[],"activeCase":null}' "$m" | _atomic_write "$m" "$td"; _ok "added project '${SC_VENDOR}/${SC_PROJECT}'"; }
cmd_project_remove() { local vp="${1:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase project remove <vendor/project>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] remove '${SC_VENDOR}/${SC_PROJECT}'"; return 0; fi; local td; td="$(_tmp_dir "$ws")"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" 'del(.vendors[$v].projects[$p])' "$ws/.staircase/manifest.json" | _atomic_write "$ws/.staircase/manifest.json" "$td"; _ok "removed '${SC_VENDOR}/${SC_PROJECT}' from manifest"; _info "directory left in place — remove manually if needed"; }
cmd_project_list() { local fv="${1:-}"; local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json"; local vs; [[ -n "$fv" ]] && vs="$fv" || vs="$(jq -r '.vendors|keys[]' "$m" 2>/dev/null || true)"; [[ -z "$vs" ]] && { _info "no projects"; return 0; }; while IFS= read -r v; do [[ -z "$v" ]] && continue; local ps; ps="$(jq -r --arg v "$v" '.vendors[$v].projects//{}|keys[]' "$m" 2>/dev/null || true)"; while IFS= read -r p; do [[ -z "$p" ]] && continue; local at; at="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].activeCase // "(none)"' "$m")"; [[ "$at" == "null" ]] && at="(none)"; local cc; cc="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components|length' "$m")"; printf "  %s%s/%s%s  case: %s  components: %s\n" "$_B" "$v" "$p" "$_Z" "$at" "$cc" >&2; done <<< "$ps"; done <<< "$vs"; }
cmd_project_info() { local vp="${1:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase project info <vendor/project>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local m="$ws/.staircase/manifest.json"; printf "\n  %s%s/%s%s\n\n" "$_B" "$SC_VENDOR" "$SC_PROJECT" "$_Z" >&2; local at; at="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p].activeCase // "(none)"' "$m")"; [[ "$at" == "null" ]] && at="(none)"; local sp; sp="$(_source_path "$ws" "$SC_VENDOR" "$SC_PROJECT")"; if [[ -n "$sp" ]]; then printf "  source:       %s\n" "$sp" >&2; else printf "  source:       %s(not linked)%s\n" "$_D" "$_Z" >&2; fi; printf "  active case:  %s\n" "$at" >&2; printf "  runner:       %s\n" "$(_runner "$ws" "$SC_VENDOR" "$SC_PROJECT" "")" >&2; local cs; cs="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p].components[]' "$m" 2>/dev/null || true)"; if [[ -z "$cs" ]]; then printf "  components:   (none)\n" >&2; else printf "  components:\n" >&2; while IFS= read -r c; do printf "    - %s\n" "$c" >&2; done <<< "$cs"; fi; printf "\n" >&2; }
cmd_project_link() { local vp="${1:-}" src="${2:-}"; [[ -z "$vp" || -z "$src" ]] && { _err "Usage: staircase project link <v/p> <path>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local canon; if ! canon="$(cd "$src" 2>/dev/null && pwd -P)"; then _err "path does not exist: '${src}'"; exit 1; fi; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] link ${SC_VENDOR}/${SC_PROJECT} → ${canon}"; return 0; fi; local m="$ws/.staircase/manifest.json" pc="$ws/$SC_VENDOR/$SC_PROJECT/.staircase/config.json" td; td="$(_tmp_dir "$ws")"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg s "$canon" '.vendors[$v].projects[$p].source = $s' "$m" | _atomic_write "$m" "$td"; jq --arg s "$canon" '.source = $s' "$pc" | _atomic_write "$pc" "$td"; _ok "linked ${SC_VENDOR}/${SC_PROJECT} → ${canon}"; }
cmd_project_unlink() { local vp="${1:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase project unlink <v/p>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] unlink ${SC_VENDOR}/${SC_PROJECT}"; return 0; fi; local m="$ws/.staircase/manifest.json" pc="$ws/$SC_VENDOR/$SC_PROJECT/.staircase/config.json" td; td="$(_tmp_dir "$ws")"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" 'del(.vendors[$v].projects[$p].source)' "$m" | _atomic_write "$m" "$td"; jq 'del(.source)' "$pc" | _atomic_write "$pc" "$td"; _ok "unlinked ${SC_VENDOR}/${SC_PROJECT}"; }
cmd_project() { local s="${1:-}"; shift || true; case "$s" in add) cmd_project_add "$@" ;; remove) cmd_project_remove "$@" ;; list|ls) cmd_project_list "$@" ;; info) cmd_project_info "$@" ;; link) cmd_project_link "$@" ;; unlink) cmd_project_unlink "$@" ;; *) _err "Usage: staircase project <add|remove|list|info|link|unlink>"; exit 1 ;; esac; }

cmd_component_add() { local vp="${1:-}"; shift || true; [[ -z "$vp" ]] && { _err "Usage: staircase component add <v/p> <comp> [...]"; exit 1; }; _parse_vp "$vp"; [[ $# -eq 0 ]] && { _err "Usage: staircase component add <v/p> <comp> [...]"; exit 1; }; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local m="$ws/.staircase/manifest.json" pc="$ws/$SC_VENDOR/$SC_PROJECT/.staircase/config.json" td; td="$(_tmp_dir "$ws")"; local c; for c in "$@"; do if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] add component '${c}'"; continue; fi; mkdir -p "$ws/$SC_VENDOR/$SC_PROJECT/$c"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg c "$c" 'if(.vendors[$v].projects[$p].components|index($c))then . else .vendors[$v].projects[$p].components+=[$c] end' "$m" | _atomic_write "$m" "$td"; jq --arg c "$c" 'if(.components|index($c))then . else .components+=[$c] end' "$pc" | _atomic_write "$pc" "$td"; _ok "added component '${c}' to ${SC_VENDOR}/${SC_PROJECT}"; done; }
cmd_component_remove() { local vp="${1:-}" c="${2:-}"; [[ -z "$vp" || -z "$c" ]] && { _err "Usage: staircase component remove <v/p> <comp>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] remove component '${c}'"; return 0; fi; local m="$ws/.staircase/manifest.json" pc="$ws/$SC_VENDOR/$SC_PROJECT/.staircase/config.json" td; td="$(_tmp_dir "$ws")"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg c "$c" '.vendors[$v].projects[$p].components-=[$c]' "$m" | _atomic_write "$m" "$td"; jq --arg c "$c" '.components-=[$c]' "$pc" | _atomic_write "$pc" "$td"; _ok "removed component '${c}'"; }
cmd_component_list() { local vp="${1:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase component list <v/p>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local cs; cs="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p].components[]' "$ws/.staircase/manifest.json" 2>/dev/null || true)"; [[ -z "$cs" ]] && { _info "no components"; return 0; }; while IFS= read -r c; do local mk="  "; [[ ! -d "$ws/$SC_VENDOR/$SC_PROJECT/$c" ]] && mk="${_R}! ${_Z}"; printf "%b%s\n" "$mk" "$c" >&2; done <<< "$cs"; }
cmd_component() { local s="${1:-}"; shift || true; case "$s" in add) cmd_component_add "$@" ;; remove) cmd_component_remove "$@" ;; list|ls) cmd_component_list "$@" ;; *) _err "Usage: staircase component <add|remove|list>"; exit 1 ;; esac; }

_build_context() { local t="$1" v="$2" p="$3" ws="$4"; local d; d="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; local cj; cj="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components' "$ws/.staircase/manifest.json")"; jq -n --arg caseId "$t" --arg vendor "$v" --arg project "$p" --arg created "$d" --argjson components "$cj" '{caseId:$caseId,vendor:$vendor,project:$project,components:$components,created:$created,stories:[],files:[],gitDiff:""}'; }

cmd_case_new() { local vp="${1:-}" tid="${2:-}"; [[ -z "$vp" || -z "$tid" ]] && { _err "Usage: staircase case new <v/p> <case-id>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local sc="$ws/$SC_VENDOR/$SC_PROJECT/.staircase" td; td="$(_tmp_dir "$ws")"; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] create case '${tid}' for ${SC_VENDOR}/${SC_PROJECT}"; return 0; fi; mkdir -p "$sc/tasks/$tid"; _build_context "$tid" "$SC_VENDOR" "$SC_PROJECT" "$ws" | _atomic_write "$sc/active/context.json" "$td"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg t "$tid" '.vendors[$v].projects[$p].activeCase=$t' "$ws/.staircase/manifest.json" | _atomic_write "$ws/.staircase/manifest.json" "$td"; _ok "created case '${tid}' for ${SC_VENDOR}/${SC_PROJECT}"; }
cmd_case_switch() { local vp="${1:-}" tid="${2:-}"; [[ -z "$vp" || -z "$tid" ]] && { _err "Usage: staircase case switch <v/p> <case-id>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local sc="$ws/$SC_VENDOR/$SC_PROJECT/.staircase" td; td="$(_tmp_dir "$ws")"; [[ ! -d "$sc/tasks/$tid" ]] && { _err "case '${tid}' not found — run: staircase case new ${SC_VENDOR}/${SC_PROJECT} ${tid}"; exit 1; }; local prev; prev="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p].activeCase // empty' "$ws/.staircase/manifest.json")"; if [[ -n "$DRY_RUN" ]]; then [[ -n "$prev" ]] && _info "[DRY RUN] save → tasks/${prev}/"; _info "[DRY RUN] load ← tasks/${tid}/"; return 0; fi; if [[ -n "$prev" && -f "$sc/active/context.json" ]]; then mkdir -p "$sc/tasks/$prev"; cp "$sc/active/context.json" "$sc/tasks/$prev/context.json"; fi; if [[ -f "$sc/tasks/$tid/context.json" ]]; then cp "$sc/tasks/$tid/context.json" "$sc/active/context.json"; else _build_context "$tid" "$SC_VENDOR" "$SC_PROJECT" "$ws" | _atomic_write "$sc/active/context.json" "$td"; fi; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg t "$tid" '.vendors[$v].projects[$p].activeCase=$t' "$ws/.staircase/manifest.json" | _atomic_write "$ws/.staircase/manifest.json" "$td"; _ok "switched to '${tid}' for ${SC_VENDOR}/${SC_PROJECT}"; }
cmd_case_list() { local vp="${1:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase case list <v/p>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local sc="$ws/$SC_VENDOR/$SC_PROJECT/.staircase"; local at; at="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p].activeCase // empty' "$ws/.staircase/manifest.json")"; [[ ! -d "$sc/tasks" ]] && return 0; local d tid mk lm; for d in "$sc/tasks"/*/; do [[ -d "$d" ]] || continue; tid="$(basename "$d")"; mk="  "; [[ "$tid" == "$at" ]] && mk="${_G}* ${_Z}"; lm="-"; [[ -f "$d/context.json" ]] && lm="$(_file_mtime "$d/context.json")"; printf "%b%-24s  %s\n" "$mk" "$tid" "$lm" >&2; done; }
cmd_case_info() { local vp="${1:-}" tid="${2:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase case info <v/p> [case-id]"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local ctx; [[ -n "$tid" ]] && ctx="$ws/$SC_VENDOR/$SC_PROJECT/.staircase/tasks/$tid/context.json" || ctx="$ws/$SC_VENDOR/$SC_PROJECT/.staircase/active/context.json"; [[ ! -f "$ctx" ]] && { _err "no context — run: staircase case new ${SC_VENDOR}/${SC_PROJECT} <case-id>"; exit 1; }; jq '.' "$ctx"; }
cmd_case() { local s="${1:-}"; shift || true; case "$s" in new) cmd_case_new "$@" ;; switch) cmd_case_switch "$@" ;; list|ls) cmd_case_list "$@" ;; info) cmd_case_info "$@" ;; *) _err "Usage: staircase case <new|switch|list|info>"; exit 1 ;; esac; }

cmd_run() { local vp="" fr="" fc=""; while [[ $# -gt 0 ]]; do case "$1" in --runner) fr="${2:-}"; shift 2 ;; --config) fc="${2:-}"; shift 2 ;; *) [[ -z "$vp" ]] && vp="$1"; shift ;; esac; done; [[ -z "$vp" ]] && { _err "Usage: staircase run <v/p> [--runner r] [--config '{...}']"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local pd="$ws/$SC_VENDOR/$SC_PROJECT" ctx="$pd/.staircase/active/context.json"; [[ ! -f "$ctx" ]] && { _err "no active context — run: staircase case new ${SC_VENDOR}/${SC_PROJECT} <case-id>"; exit 1; }; local runner; runner="$(_runner "$ws" "$SC_VENDOR" "$SC_PROJECT" "$fr")"; local sp; sp="$(_source_path "$ws" "$SC_VENDOR" "$SC_PROJECT")"; if [[ -n "$DRY_RUN" ]]; then [[ -n "$fc" ]] && _info "[DRY RUN] merge config into context"; if [[ -n "$sp" ]]; then _info "[DRY RUN] cd ${sp} && ${runner} --prd ${ctx}"; else _info "[DRY RUN] cd ${SC_VENDOR}/${SC_PROJECT} && ${runner} --prd .staircase/active/context.json"; fi; return 0; fi; if [[ -n "$fc" ]]; then local td; td="$(_tmp_dir "$ws")"; jq --argjson cfg "$fc" '.+{agentConfig:$cfg}' "$ctx" | _atomic_write "$ctx" "$td"; fi; _info "launching ${runner} for ${SC_VENDOR}/${SC_PROJECT}"; local rc=0; if [[ -n "$sp" ]]; then cd "$sp" || { _err "cd failed: ${sp}"; exit 1; }; "$runner" --prd "$ctx" || rc=$?; else cd "$pd" || { _err "cd failed"; exit 1; }; "$runner" --prd .staircase/active/context.json || rc=$?; fi; local hd; hd="$(_hooks_dir "$ws")"; [[ -x "$hd/99-post-run.sh" ]] && { _info "post-run hook"; "$hd/99-post-run.sh" || true; }; return "$rc"; }

cmd_ls() { local ws; if ! ws="$(_ws_root)"; then _info "no workspace — run: staircase init"; return 0; fi; _require_jq; local m="$ws/.staircase/manifest.json" wn; wn="$(jq -r '.name // "-"' "$ws/.staircase/config.json" 2>/dev/null)"; printf "%s%s%s  %s(%s)%s\n" "$_B" "$wn" "$_Z" "$_D" "$ws" "$_Z" >&2; local vs; vs="$(jq -r '.vendors|keys[]' "$m" 2>/dev/null || true)"; [[ -z "$vs" ]] && return 0; local va=(); while IFS= read -r v; do [[ -z "$v" ]] && continue; va+=("$v"); done <<< "$vs"; local vt=${#va[@]} vi=0; for v in "${va[@]}"; do vi=$((vi+1)); local vb="├──" vi2="│   "; [[ $vi -eq $vt ]] && { vb="└──"; vi2="    "; }; printf "%s %s%s%s\n" "$vb" "$_C" "$v" "$_Z" >&2; local ps; ps="$(jq -r --arg v "$v" '.vendors[$v].projects|keys[]' "$m" 2>/dev/null || true)"; [[ -z "$ps" ]] && continue; local pa=(); while IFS= read -r p; do [[ -z "$p" ]] && continue; pa+=("$p"); done <<< "$ps"; local pt=${#pa[@]} pi=0; for p in "${pa[@]}"; do pi=$((pi+1)); local pb="├──" pi2="│   "; [[ $pi -eq $pt ]] && { pb="└──"; pi2="    "; }; local at; at="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].activeCase // empty' "$m")"; [[ -z "$at" ]] && at="(none)"; local cc; cc="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components|length' "$m")"; printf "%s%s %s%s%s\n" "$vi2" "$pb" "$_B" "$p" "$_Z" >&2; if [[ "$at" == "(none)" ]]; then printf "%s%s├── case:       %s\n" "$vi2" "$pi2" "$at" >&2; else printf "%s%s├── case:       %s%s%s\n" "$vi2" "$pi2" "$_G" "$at" "$_Z" >&2; fi; local lsp; lsp="$(_source_path "$ws" "$v" "$p")"; local lind=""; [[ -n "$lsp" ]] && lind=" ${_C}[→ linked]${_Z}"; printf "%s%s└── components: %s%b\n" "$vi2" "$pi2" "$cc" "$lind" >&2; done; done; }

cmd_status() { local jf=0; for a in "$@"; do [[ "$a" == "--json" ]] && jf=1; done; local ws; if ! ws="$(_ws_root)"; then [[ $jf -eq 1 ]] && printf '{"version":"1.0","vendors":{}}\n' || _info "no workspace"; return 0; fi; _require_jq; local m="$ws/.staircase/manifest.json"; [[ $jf -eq 1 ]] && { jq '.' "$m"; return 0; }; printf "%-12s  %-20s  %-16s  %-6s  %-3s  %s\n" "VENDOR" "PROJECT" "ACTIVE CASE" "COMPS" "SRC" "MODIFIED" >&2; printf "%-12s  %-20s  %-16s  %-6s  %-3s  %s\n" "------------" "--------------------" "----------------" "------" "---" "-------------------" >&2; local vs; vs="$(jq -r '.vendors|keys[]' "$m" 2>/dev/null || true)"; [[ -z "$vs" ]] && return 0; while IFS= read -r v; do [[ -z "$v" ]] && continue; local ps; ps="$(jq -r --arg v "$v" '.vendors[$v].projects//{}|keys[]' "$m" 2>/dev/null || true)"; while IFS= read -r p; do [[ -z "$p" ]] && continue; local at cc lm ctx; at="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].activeCase//"(none)"' "$m")"; [[ "$at" == "null" ]] && at="(none)"; cc="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components|length' "$m")"; lm="-"; ctx="$ws/$v/$p/.staircase/active/context.json"; [[ -f "$ctx" ]] && lm="$(_file_mtime "$ctx")"; local ssp; ssp="$(_source_path "$ws" "$v" "$p")"; local sind="-"; [[ -n "$ssp" ]] && sind="✓"; printf "%-12s  %-20s  %-16s  %-6s  %-3s  %s\n" "$v" "$p" "$at" "$cc" "$sind" "$lm" >&2; done <<< "$ps"; done <<< "$vs"; }

cmd_doctor() { local fix=0; for a in "$@"; do [[ "$a" == "--fix" ]] && fix=1; done; local ws; if ! ws="$(_ws_root)"; then _info "no workspace — run: staircase init"; return 0; fi; local issues=0 fixed=0 m="$ws/.staircase/manifest.json" td; td="$(_tmp_dir "$ws")"; if [[ ! -f "$ws/.staircase/config.json" ]]; then _warn "config.json missing"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { jq -n '{version:"1.0",name:"workspace",runner:"ralph-tui",hooks_dir:"hooks.d",defaults:{}}' > "$ws/.staircase/config.json"; _ok "repaired config.json"; fixed=$((fixed+1)); }; fi; if [[ ! -f "$m" ]]; then _warn "manifest.json missing"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { printf '{"version":"1.0","vendors":{}}\n' > "$m"; _ok "repaired manifest.json"; fixed=$((fixed+1)); }; elif command -v jq &>/dev/null && ! jq empty "$m" 2>/dev/null; then _warn "manifest.json: invalid JSON"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { printf '{"version":"1.0","vendors":{}}\n' > "$m"; _ok "repaired manifest.json"; fixed=$((fixed+1)); }; fi; if [[ ! -d "$td" ]]; then _warn "tmp/ missing"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { mkdir -p "$td"; _ok "repaired tmp/"; fixed=$((fixed+1)); }; fi; if command -v jq &>/dev/null && [[ -f "$m" ]] && jq empty "$m" 2>/dev/null; then local vs; vs="$(jq -r '.vendors|keys[]' "$m" 2>/dev/null || true)"; while IFS= read -r v; do [[ -z "$v" ]] && continue; [[ ! -d "$ws/$v" ]] && { _warn "vendor '${v}': dir missing"; issues=$((issues+1)); continue; }; local ps; ps="$(jq -r --arg v "$v" '.vendors[$v].projects|keys[]' "$m" 2>/dev/null || true)"; while IFS= read -r p; do [[ -z "$p" ]] && continue; local pd="$ws/$v/$p"; [[ ! -d "$pd/.staircase" ]] && { _warn "${v}/${p}: .staircase/ missing"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { mkdir -p "$pd/.staircase/active" "$pd/.staircase/tasks"; _ok "repaired ${v}/${p}/.staircase/"; fixed=$((fixed+1)); }; }; local at; at="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].activeCase // empty' "$m")"; [[ -n "$at" && "$at" != "null" && ! -f "$pd/.staircase/active/context.json" ]] && { _warn "${v}/${p}: activeCase but no context.json"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { mkdir -p "$pd/.staircase/active"; printf '{}' > "$pd/.staircase/active/context.json"; _ok "repaired context.json for ${v}/${p}"; fixed=$((fixed+1)); }; }; local cs; cs="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components[]' "$m" 2>/dev/null || true)"; while IFS= read -r c; do [[ -z "$c" ]] && continue; [[ ! -d "$pd/$c" ]] && { _warn "${v}/${p}/${c}: dir missing"; issues=$((issues+1)); }; done <<< "$cs"; local dsp; dsp="$(_source_path "$ws" "$v" "$p")"; [[ -n "$dsp" && ! -d "$dsp" ]] && { _warn "${v}/${p}: source path missing: ${dsp}"; issues=$((issues+1)); }; done <<< "$ps"; done <<< "$vs"; fi; if [[ $issues -eq 0 ]]; then _ok "workspace is healthy"; return 0; fi; local rem=$((issues-fixed)); [[ $rem -eq 0 ]] && { _ok "all issues repaired"; return 0; }; _err "${rem} issue(s) remaining"; return 1; }

cmd_export() { local vp="" fmt="json"; while [[ $# -gt 0 ]]; do case "$1" in --format) fmt="${2:-json}"; shift 2 ;; *) [[ -z "$vp" ]] && vp="$1"; shift ;; esac; done; [[ -z "$vp" ]] && { _err "Usage: staircase export <v/p> [--format json|tar]"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local sc="$ws/$SC_VENDOR/$SC_PROJECT/.staircase"; case "$fmt" in json) if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] export JSON to stdout"; return 0; fi; local ea pm ac tj; ea="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; pm="$(jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p]' "$ws/.staircase/manifest.json")"; ac="null"; [[ -f "$sc/active/context.json" ]] && ac="$(jq '.' "$sc/active/context.json")"; tj="{}"; if [[ -d "$sc/tasks" ]]; then local d t; for d in "$sc/tasks"/*/; do [[ -d "$d" ]] || continue; t="$(basename "$d")"; [[ -f "$d/context.json" ]] && tj="$(jq --arg t "$t" --argjson c "$(jq '.' "$d/context.json")" '.+{($t):$c}' <<< "$tj")" || tj="$(jq --arg t "$t" '.+{($t):null}' <<< "$tj")"; done; fi; jq -n --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg ea "$ea" --argjson m "$pm" --argjson a "$ac" --argjson t "$tj" '{vendor:$v,project:$p,exported_at:$ea,manifest:$m,agent:{active:$a,tasks:$t}}' ;; tar) local ds tf; ds="$(date -u +%Y-%m-%d)"; tf="staircase-export-${SC_VENDOR}-${SC_PROJECT}-${ds}.tar.gz"; [[ -n "$DRY_RUN" ]] && { _info "[DRY RUN] create ${tf}"; return 0; }; tar czf "$tf" -C "$ws" "${SC_VENDOR}/${SC_PROJECT}/.staircase/"; _ok "exported to ${tf}" ;; *) _err "Unknown format: '${fmt}'"; exit 1 ;; esac; }

cmd_hooks_install() { local vp="${1:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase hooks install <v/p>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local hd; hd="$(_hooks_dir "$ws")"; local pd="$ws/$SC_VENDOR/$SC_PROJECT" guard='# >>> stAirCase hooks <<<'; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] create hooks stubs + git hooks"; return 0; fi; mkdir -p "$hd"; [[ ! -f "$hd/01-format.sh" ]] && { printf '#!/usr/bin/env bash\n# hooks.d/01-format.sh — format hook stub\n' > "$hd/01-format.sh"; chmod +x "$hd/01-format.sh"; _ok "created 01-format.sh"; }; [[ ! -f "$hd/99-post-run.sh" ]] && { printf '#!/usr/bin/env bash\n# hooks.d/99-post-run.sh — post-run hook stub\n' > "$hd/99-post-run.sh"; chmod +x "$hd/99-post-run.sh"; _ok "created 99-post-run.sh"; }; local dirs=("$pd"); local cs; cs="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p].components[]' "$ws/.staircase/manifest.json" 2>/dev/null || true)"; while IFS= read -r c; do [[ -z "$c" ]] && continue; dirs+=("$pd/$c"); done <<< "$cs"; local dir gd; for dir in "${dirs[@]}"; do gd="$dir/.git"; [[ -d "$gd" ]] || continue; mkdir -p "$gd/hooks"; local hn; hn="$(basename "$dir")"; [[ "$dir" == "$pd" ]] && hn="${SC_VENDOR}/${SC_PROJECT}"; local pc="$gd/hooks/pre-commit"; if ! { [[ -f "$pc" ]] && grep -qF "$guard" "$pc" 2>/dev/null; }; then [[ ! -f "$pc" ]] && printf '#!/usr/bin/env bash\n' > "$pc"; printf '\n%s\n[ -x "%s/01-format.sh" ] && "%s/01-format.sh"\n# <<< stAirCase hooks <<<\n' "$guard" "$hd" "$hd" >> "$pc"; chmod +x "$pc"; _ok "pre-commit hook for ${hn}"; fi; local pm="$gd/hooks/post-merge"; if ! { [[ -f "$pm" ]] && grep -qF "$guard" "$pm" 2>/dev/null; }; then [[ ! -f "$pm" ]] && printf '#!/usr/bin/env bash\n' > "$pm"; printf '\n%s\ncommand -v staircase &>/dev/null && staircase doctor --fix >/dev/null 2>&1 || true\n# <<< stAirCase hooks <<<\n' "$guard" >> "$pm"; chmod +x "$pm"; _ok "post-merge hook for ${hn}"; fi; done; }
cmd_hooks() { local s="${1:-}"; shift || true; case "$s" in install) cmd_hooks_install "$@" ;; *) _err "Usage: staircase hooks install <v/p>"; exit 1 ;; esac; }

_usage() { cat >&2 << EOF
${_B}staircase${_Z} — AI workspace orchestrator v${VERSION}

Usage: staircase [--dry-run] <command> [args]

${_B}Workspace${_Z}
  init [--name <n>]                        Create workspace
  config [<key>] [<value>]                 Get/set config
  config --list                            Show resolved config

${_B}Structure${_Z}
  vendor add|remove|list                   Manage vendors
  project add|remove|list|info             Manage projects (vendor/project)
  project link <v/p> <path>               Link external source directory
  project unlink <v/p>                    Remove source link
  component add|remove|list                Manage components

${_B}Cases${_Z}
  case new <v/p> <case-id>                 Create case
  case switch <v/p> <case-id>              Switch case
  case list <v/p>                          List cases
  case info <v/p> [case-id]                Show context

${_B}Agent${_Z}
  run <v/p> [--runner <r>] [--config '{}'] Launch agent

${_B}Inspection${_Z}
  ls                                       Tree view
  status [--json]                          Table / JSON
  doctor [--fix]                           Health check
  export <v/p> [--format json|tar]         Export context

${_B}Hooks${_Z}
  hooks install <v/p>                      Install git hooks

${_B}Environment${_Z}
  STAIRCASE_DIR    STAIRCASE_TMP_DIR    STAIRCASE_HOOKS_DIR
  STAIRCASE_RUNNER STAIRCASE_DEBUG      NO_COLOR

EOF
}

main() { local args=(); for arg in "$@"; do case "$arg" in --dry-run) DRY_RUN=1 ;; --no-color) NO_COLOR=1; _R=''; _G=''; _Y=''; _C=''; _B=''; _D=''; _Z='' ;; --debug) export STAIRCASE_DEBUG=1 ;; --version) printf 'staircase %s\n' "$VERSION"; exit 0 ;; *) args+=("$arg") ;; esac; done; set -- "${args[@]+"${args[@]}"}"; [[ -n "${STAIRCASE_DEBUG:-}" ]] && set -x; local cmd="${1:-help}"; shift || true; case "$cmd" in init) cmd_init "$@" ;; config) cmd_config "$@" ;; vendor) cmd_vendor "$@" ;; project) cmd_project "$@" ;; component) cmd_component "$@" ;; case) cmd_case "$@" ;; run) cmd_run "$@" ;; ls) cmd_ls "$@" ;; status) cmd_status "$@" ;; doctor) cmd_doctor "$@" ;; export) cmd_export "$@" ;; hooks) cmd_hooks "$@" ;; help|--help|-h) _usage ;; *) _err "Unknown command: '${cmd}'"; _usage; exit 1 ;; esac; }

main "$@"
