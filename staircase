cmd_case_switch() { local vp="${1:-}" id="${2:-}"; [[ -z "$vp" || -z "$id" ]] && { _err "Usage: staircase case switch <v/p> <case-id>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local prd_path; prd_path="$(_prd_file "$ws" "$SC_VENDOR" "$SC_PROJECT" "$id")"; [[ ! -f "$prd_path" ]] && { _err "case '${id}' not found"; exit 1; }; local td; td="$(_tmp_dir "$ws")"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg lc "$id" '.vendors[$v].projects[$p].lastCase = $lc' "$ws/.staircase/manifest.json" | _atomic_write "$ws/.staircase/manifest.json" "$td"; _ok "switched ${SC_VENDOR}/${SC_PROJECT} → ${id}"; }
