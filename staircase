cmd_run() { local vp="" id="" fr="" fc=""; while [[ $# -gt 0 ]]; do case "$1" in --runner) fr="${2:-}"; shift 2 ;; --config) fc="${2:-}"; shift 2 ;; *) if [[ -z "$vp" ]]; then vp="$1"; elif [[ -z "$id" ]]; then id="$1"; fi; shift ;; esac; done; [[ -z "$vp" ]] && { _err "Usage: staircase run <v/p|v> [case-id] [--runner r] [--config '{}']"; exit 1; }; SC_VENDOR=""; SC_PROJECT=""; _parse_vp_or_v "$vp"; local ws; ws="$(_require_ws)"; _require_jq; if [[ -n "$SC_PROJECT" ]]; then _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; fi; if [[ -z "$id" ]]; then [[ -z "$SC_PROJECT" ]] && { _err "vendor-scope run requires an explicit case-id"; exit 1; }; id="$(_last_case "$ws" "$SC_VENDOR" "$SC_PROJECT")"; [[ -z "$id" || "$id" == "null" ]] && { _err "no lastCase set for ${SC_VENDOR}/${SC_PROJECT} — run: staircase case new ${vp} <id>"; exit 1; }; _info "using lastCase: ${id}"; fi; local ns; ns="$(_prd_ns "$SC_VENDOR" "$SC_PROJECT" "$id")"; local prd_path; prd_path="$(_prd_file "$ws" "$SC_VENDOR" "$SC_PROJECT" "$id")"; [[ ! -f "$prd_path" ]] && { _err "case '${ns}' not found — run: staircase case new ${vp} ${id}"; exit 1; }; local runner; runner="$(_runner "$ws" "$SC_VENDOR" "$SC_PROJECT" "$fr")"; if ! command -v "$runner" &>/dev/null; then _err "runner not found in PATH: '${runner}' — install it or set STAIRCASE_RUNNER=<path> or --runner <path>"; exit 1; fi; local td; td="$(_tmp_dir "$ws")"; if [[ -n "$DRY_RUN" ]]; then [[ -n "$fc" ]] && _info "[DRY RUN] merge config into prd"; if [[ -n "$SC_PROJECT" ]]; then local sp; sp="$(_source_path "$ws" "$SC_VENDOR" "$SC_PROJECT")"; if [[ -n "$sp" ]]; then _info "[DRY RUN] cd ${sp} && ${runner} --prd ${prd_path}"; else _info "[DRY RUN] cd ${ws}/${SC_VENDOR}/${SC_PROJECT} && ${runner} --prd ${prd_path}"; fi; else _info "[DRY RUN] cd ${ws}/${SC_VENDOR} && ${runner} --prd ${prd_path}"; fi; return 0; fi; local actual_prd="$prd_path"; if [[ -n "$fc" ]]; then local tmp_prd; tmp_prd="$(mktemp "$td/sc.prd.XXXXXX")"; trap 'rm -f "${tmp_prd:-}"' EXIT; jq --argjson cfg "$fc" '.+{agentConfig:$cfg}' "$prd_path" > "$tmp_prd"; actual_prd="$tmp_prd"; fi; _info "launching ${runner} for ${ns}"; local rc=0; if [[ -n "$SC_PROJECT" ]]; then local sp; sp="$(_source_path "$ws" "$SC_VENDOR" "$SC_PROJECT")"; if [[ -n "$sp" ]]; then cd "$sp" || { _err "cd failed: ${sp}"; exit 1; }; else cd "$ws/$SC_VENDOR/$SC_PROJECT" || { _err "cd failed"; exit 1; }; fi; else cd "$ws/$SC_VENDOR" || { _err "cd failed"; exit 1; }; fi; "$runner" --prd "$actual_prd" || rc=$?; if [[ -n "$SC_PROJECT" ]]; then jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg lc "$id" '.vendors[$v].projects[$p].lastCase = $lc' "$ws/.staircase/manifest.json" | _atomic_write "$ws/.staircase/manifest.json" "$td"; fi; local hd; hd="$(_hooks_dir "$ws")"; [[ -x "$hd/99-post-run.sh" ]] && { _info "post-run hook"; "$hd/99-post-run.sh" || true; }; return "$rc"; }

cmd_ls() { local jf=0; for a in "$@"; do [[ "$a" == "--json" ]] && jf=1; done; local ws; if ! ws="$(_ws_root)"; then _info "no workspace — run: staircase init"; return 0; fi; _require_jq; local m="$ws/.staircase/manifest.json" wn; wn="$(jq -r '.name // "-"' "$ws/.staircase/config.json" 2>/dev/null)"; printf "%s%s%s  %s(%s)%s\n" "$_B" "$wn" "$_Z" "$_D" "$ws" "$_Z" >&2; local vs; vs="$(jq -r '.vendors|keys[]' "$m" 2>/dev/null || true)"; [[ -z "$vs" ]] && { [[ $jf -eq 1 ]] && printf '{"workspace":"%s","path":"%s","vendors":{}}\n' "$wn" "$ws" || true; return 0; }; if [[ $jf -eq 1 ]]; then local jo; jo="$(jq -n --arg wn "$wn" --arg ws "$ws" '{workspace:$wn,path:$ws,vendors:{}}')"; while IFS= read -r v; do [[ -z "$v" ]] && continue; local vc=0; for f in "$(_prd_dir "$ws")/$v"/*.json; do [[ -f "$f" ]] && vc=$((vc+1)); done; local ps2; ps2="$(jq -r --arg v "$v" '.vendors[$v].projects//{}|keys[]' "$m" 2>/dev/null||true)"; local pjo="{}"; while IFS= read -r p; do [[ -z "$p" ]] && continue; local lc2; lc2="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].lastCase//"(none)"' "$m")"; [[ "$lc2" == "null" ]] && lc2="(none)"; local cc2; cc2="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components|length' "$m")"; local cnt2=0; for f in "$(_prd_dir "$ws")/$v/$p"/*.json; do [[ -f "$f" ]] && cnt2=$((cnt2+1)); done; local src2; src2="$(_source_path "$ws" "$v" "$p")"; pjo="$(jq --arg p "$p" --arg lc "$lc2" --argjson cases "$cnt2" --argjson comps "$cc2" --arg src "${src2:-}" '.[$p]={lastCase:(if $lc=="(none)" then null else $lc end),cases:$cases,components:$comps,source:(if $src=="" then null else $src end)}' <<< "$pjo")"; done <<< "$ps2"; jo="$(jq --arg v "$v" --argjson vc "$vc" --argjson pjo "$pjo" '.vendors[$v]={vendorCases:$vc,projects:$pjo}' <<< "$jo")"; done <<< "$vs"; printf '%s\n' "$jo"; return 0; fi; local va=(); while IFS= read -r v; do [[ -z "$v" ]] && continue; va+=("$v"); done <<< "$vs"; local vt=${#va[@]} vi=0; for v in "${va[@]}"; do vi=$((vi+1)); local vb="├──" vi2="│   "; [[ $vi -eq $vt ]] && { vb="└──"; vi2="    "; }; local vc_count=0; local prd_dir; prd_dir="$(_prd_dir "$ws")"; for f in "$prd_dir/$v"/*.json; do [[ -f "$f" ]] || continue; vc_count=$((vc_count+1)); done; if [[ $vc_count -gt 0 ]]; then printf "%s %s%s%s  %s(%s vendor case%s)%s\n" "$vb" "$_C" "$v" "$_Z" "$_D" "$vc_count" "$([[ $vc_count -eq 1 ]] && echo "" || echo "s")" "$_Z" >&2; else printf "%s %s%s%s\n" "$vb" "$_C" "$v" "$_Z" >&2; fi; local ps; ps="$(jq -r --arg v "$v" '.vendors[$v].projects|keys[]' "$m" 2>/dev/null || true)"; [[ -z "$ps" ]] && continue; local pa=(); while IFS= read -r p; do [[ -z "$p" ]] && continue; pa+=("$p"); done <<< "$ps"; local pt=${#pa[@]} pi=0; for p in "${pa[@]}"; do pi=$((pi+1)); local pb="├──" pi2="│   "; [[ $pi -eq $pt ]] && { pb="└──"; pi2="    "; }; local lc; lc="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].lastCase // empty' "$m")"; [[ -z "$lc" || "$lc" == "null" ]] && lc="(none)"; local cc; cc="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components|length' "$m")"; local cases_count=0; for f in "$prd_dir/$v/$p"/*.json; do [[ -f "$f" ]] || continue; cases_count=$((cases_count+1)); done; printf "%s%s %s%s%s\n" "$vi2" "$pb" "$_B" "$p" "$_Z" >&2; if [[ "$lc" == "(none)" ]]; then printf "%s%s├── last case:  %s\n" "$vi2" "$pi2" "$lc" >&2; else printf "%s%s├── last case:  %s%s%s\n" "$vi2" "$pi2" "$_G" "$lc" "$_Z" >&2; fi; printf "%s%s├── cases:      %s\n" "$vi2" "$pi2" "$cases_count" >&2; local lind=""; local pd="$ws/$v/$p"; if [[ -L "$pd" ]]; then local tgt; tgt="$(readlink "$pd")"; lind=" ${_C}[→ ${tgt}]${_Z}"; elif [[ -n "$(_source_path "$ws" "$v" "$p")" ]]; then lind=" ${_C}[→ linked]${_Z}"; fi; printf "%s%s└── components: %s%b\n" "$vi2" "$pi2" "$cc" "$lind" >&2; done; done; }

cmd_status() { local jf=0; for a in "$@"; do [[ "$a" == "--json" ]] && jf=1; done; local ws; if ! ws="$(_ws_root)"; then [[ $jf -eq 1 ]] && printf '{"version":"1.2","vendors":{}}\n' || _info "no workspace"; return 0; fi; _require_jq; local m="$ws/.staircase/manifest.json"; [[ $jf -eq 1 ]] && { jq '.' "$m"; return 0; }; printf "%-12s  %-20s  %-16s  %-5s  %-3s  %s\n" "VENDOR" "PROJECT" "LAST CASE" "CASES" "SRC" "MODIFIED" >&2; printf "%-12s  %-20s  %-16s  %-5s  %-3s  %s\n" "------------" "--------------------" "----------------" "-----" "---" "-------------------" >&2; local vs; vs="$(jq -r '.vendors|keys[]' "$m" 2>/dev/null || true)"; [[ -z "$vs" ]] && return 0; local prd_dir; prd_dir="$(_prd_dir "$ws")"; while IFS= read -r v; do [[ -z "$v" ]] && continue; local ps; ps="$(jq -r --arg v "$v" '.vendors[$v].projects//{}|keys[]' "$m" 2>/dev/null || true)"; while IFS= read -r p; do [[ -z "$p" ]] && continue; local lc; lc="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].lastCase//"(none)"' "$m")"; [[ "$lc" == "null" ]] && lc="(none)"; local cc; cc="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components|length' "$m")"; local cases_count=0; local lm="-"; for f in "$prd_dir/$v/$p"/*.json; do [[ -f "$f" ]] || continue; cases_count=$((cases_count+1)); done; if [[ "$lc" != "(none)" ]]; then local lc_ns; lc_ns="$(_prd_ns "$v" "$p" "$lc")"; local lc_f; lc_f="$(_prd_file "$ws" "$v" "$p" "$lc")"; [[ -f "$lc_f" ]] && lm="$(_file_mtime "$lc_f")"; fi; local ssp; ssp="$(_source_path "$ws" "$v" "$p")"; local sind="-"; [[ -n "$ssp" ]] && sind="✓"; printf "%-12s  %-20s  %-16s  %-5s  %-3s  %s\n" "$v" "$p" "$lc" "$cases_count" "$sind" "$lm" >&2; done <<< "$ps"; done <<< "$vs"; }

cmd_doctor() { local fix=0; for a in "$@"; do [[ "$a" == "--fix" ]] && fix=1; done; local ws; if ! ws="$(_ws_root)"; then _info "no workspace — run: staircase init"; return 0; fi; local issues=0 fixed=0 m="$ws/.staircase/manifest.json" td; td="$(_tmp_dir "$ws")"; if [[ ! -f "$ws/.staircase/config.json" ]]; then _warn "config.json missing"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { jq -n '{version:"1.2",name:"workspace",runner:"ralph-tui",hooks_dir:"hooks.d",defaults:{}}' > "$ws/.staircase/config.json"; _ok "repaired config.json"; fixed=$((fixed+1)); }; fi; if [[ ! -f "$m" ]]; then _warn "manifest.json missing"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { printf '{"version":"1.2","vendors":{}}\n' > "$m"; _ok "repaired manifest.json"; fixed=$((fixed+1)); }; elif command -v jq &>/dev/null && ! jq empty "$m" 2>/dev/null; then _warn "manifest.json: invalid JSON"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { printf '{"version":"1.2","vendors":{}}\n' > "$m"; _ok "repaired manifest.json"; fixed=$((fixed+1)); }; fi; if [[ ! -d "$td" ]]; then _warn "tmp/ missing"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { mkdir -p "$td"; _ok "repaired tmp/"; fixed=$((fixed+1)); }; fi; if [[ -f "$ws/.staircase/config.json" ]] && command -v jq &>/dev/null; then local ws_ver; ws_ver="$(jq -r '.version // "1.0"' "$ws/.staircase/config.json" 2>/dev/null)"; if [[ "$ws_ver" != "${VERSION%.*}" ]]; then _warn "workspace version ${ws_ver} < script ${VERSION%.*} — run: staircase migrate"; issues=$((issues+1)); fi; fi; local prd_dir; prd_dir="$(_prd_dir "$ws")"; if [[ ! -d "$prd_dir" ]]; then _warn "prd/ missing"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { mkdir -p "$prd_dir"; _ok "repaired prd/"; fixed=$((fixed+1)); }; fi; if command -v jq &>/dev/null && [[ -f "$m" ]] && jq empty "$m" 2>/dev/null; then for f in "$prd_dir"/*/*/*.json "$prd_dir"/*/*.json; do [[ -f "$f" ]] || continue; if ! jq empty "$f" 2>/dev/null; then _warn "prd file invalid JSON: $(basename "$f")"; issues=$((issues+1)); continue; fi; local fid; fid="$(jq -r '.id // empty' "$f" 2>/dev/null)"; local expected_id fid_case; expected_id="$(basename "$f" .json)"; fid_case="${fid##*.}"; if [[ -n "$fid" && "$fid_case" != "$expected_id" ]]; then _warn "prd id mismatch: $(basename "$f") has id '${fid}'"; issues=$((issues+1)); fi; done; for f in "$prd_dir"/*.json; do [[ -f "$f" ]] || continue; _warn "flat PRD file found: $(basename "$f") — run: staircase migrate"; issues=$((issues+1)); done; local vs; vs="$(jq -r '.vendors|keys[]' "$m" 2>/dev/null || true)"; while IFS= read -r v; do [[ -z "$v" ]] && continue; [[ ! -d "$ws/$v" ]] && { _warn "vendor '${v}': dir missing"; issues=$((issues+1)); [[ $fix -eq 1 ]] && { mkdir -p "$ws/$v"; _ok "repaired vendor dir '${v}'"; fixed=$((fixed+1)); }; continue; }; local ps; ps="$(jq -r --arg v "$v" '.vendors[$v].projects|keys[]' "$m" 2>/dev/null || true)"; while IFS= read -r p; do [[ -z "$p" ]] && continue; local pd="$ws/$v/$p"; if [[ -d "$pd/.staircase" ]]; then _warn "${v}/${p}: per-project .staircase/ found — run: staircase migrate"; issues=$((issues+1)); fi; local dsp; dsp="$(_source_path "$ws" "$v" "$p")"; if [[ -n "$dsp" ]]; then if [[ -L "$pd" ]]; then [[ ! -e "$pd" ]] && { _warn "${v}/${p}: symlink target missing: ${dsp}"; issues=$((issues+1)); }; elif [[ ! -d "$dsp" ]]; then _warn "${v}/${p}: source path missing: ${dsp}"; issues=$((issues+1)); fi; fi; local cs; cs="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components[]' "$m" 2>/dev/null || true)"; while IFS= read -r c; do [[ -z "$c" ]] && continue; [[ ! -d "$pd/$c" ]] && { _warn "${v}/${p}/${c}: component dir missing"; issues=$((issues+1)); }; done <<< "$cs"; done <<< "$ps"; done <<< "$vs"; fi; if [[ $issues -eq 0 ]]; then _ok "workspace is healthy"; return 0; fi; local rem=$((issues-fixed)); [[ $rem -eq 0 ]] && { _ok "all issues repaired"; return 0; }; _err "${rem} issue(s) remaining"; return 1; }

cmd_export() { local vp="" fmt="json"; while [[ $# -gt 0 ]]; do case "$1" in --format) fmt="${2:-json}"; shift 2 ;; *) [[ -z "$vp" ]] && vp="$1"; shift ;; esac; done; [[ -z "$vp" ]] && { _err "Usage: staircase export <v/p> [--format json|tar]"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local prd_dir; prd_dir="$(_prd_dir "$ws")"; case "$fmt" in json) if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] export JSON to stdout"; return 0; fi; local ea pm cj; ea="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; pm="$(jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p]' "$ws/.staircase/manifest.json")"; cj="{}"; for f in "$prd_dir/$SC_VENDOR/$SC_PROJECT"/*.json; do [[ -f "$f" ]] || continue; local cid; cid="$(basename "$f" .json)"; cj="$(jq --arg cid "$cid" --argjson c "$(jq '.' "$f")" '.+{($cid):$c}' <<< "$cj")"; done; jq -n --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg ea "$ea" --argjson m "$pm" --argjson cases "$cj" '{vendor:$v,project:$p,exported_at:$ea,manifest:$m,cases:$cases}' ;; tar) local ds tf; ds="$(date -u +%Y-%m-%d)"; tf="staircase-export-${SC_VENDOR}-${SC_PROJECT}-${ds}.tar.gz"; [[ -n "$DRY_RUN" ]] && { _info "[DRY RUN] create ${tf}"; return 0; }; local tmp_dir_export; tmp_dir_export="$(mktemp -d)"; trap 'rm -rf "${tmp_dir_export:-}"' EXIT; mkdir -p "$tmp_dir_export/prd"; for f in "$prd_dir/$SC_VENDOR/$SC_PROJECT"/*.json; do [[ -f "$f" ]] || continue; cp "$f" "$tmp_dir_export/prd/"; done; tar czf "$tf" -C "$tmp_dir_export" prd/; _ok "exported to ${tf}" ;; langgraph) if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] export LangGraph stub to stdout"; return 0; fi; jq -n --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '{_stub:true,format:"langgraph-0.1",vendor:$v,project:$p,nodes:[],edges:[],TODO:"populate nodes from userStories"}'; _warn "LangGraph export is a stub — populate nodes from case userStories" ;; *) _err "Unknown format: '${fmt}' (json|tar|langgraph)"; exit 1 ;; esac; }

cmd_hooks_install() { local vp="${1:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase hooks install <v/p>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local hd; hd="$(_hooks_dir "$ws")"; local pd="$ws/$SC_VENDOR/$SC_PROJECT" guard='# >>> stAirCase hooks <<<'; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] create hooks stubs + git hooks"; return 0; fi; mkdir -p "$hd"; [[ ! -f "$hd/01-format.sh" ]] && { printf '#!/usr/bin/env bash\n# hooks.d/01-format.sh — format hook stub\n' > "$hd/01-format.sh"; chmod +x "$hd/01-format.sh"; _ok "created 01-format.sh"; }; [[ ! -f "$hd/99-post-run.sh" ]] && { printf '#!/usr/bin/env bash\n# hooks.d/99-post-run.sh — post-run hook stub\n' > "$hd/99-post-run.sh"; chmod +x "$hd/99-post-run.sh"; _ok "created 99-post-run.sh"; }; local dirs=("$pd"); local cs; cs="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p].components[]' "$ws/.staircase/manifest.json" 2>/dev/null || true)"; while IFS= read -r c; do [[ -z "$c" ]] && continue; dirs+=("$pd/$c"); done <<< "$cs"; local dir gd; for dir in "${dirs[@]}"; do gd="$dir/.git"; [[ -d "$gd" ]] || continue; mkdir -p "$gd/hooks"; local hn; hn="$(basename "$dir")"; [[ "$dir" == "$pd" ]] && hn="${SC_VENDOR}/${SC_PROJECT}"; local pc="$gd/hooks/pre-commit"; if ! { [[ -f "$pc" ]] && grep -qF "$guard" "$pc" 2>/dev/null; }; then [[ ! -f "$pc" ]] && printf '#!/usr/bin/env bash\n' > "$pc"; printf '\n%s\n[ -x "%s/01-format.sh" ] && "%s/01-format.sh"\n# <<< stAirCase hooks <<<\n' "$guard" "$hd" "$hd" >> "$pc"; chmod +x "$pc"; _ok "pre-commit hook for ${hn}"; fi; local pm="$gd/hooks/post-merge"; if ! { [[ -f "$pm" ]] && grep -qF "$guard" "$pm" 2>/dev/null; }; then [[ ! -f "$pm" ]] && printf '#!/usr/bin/env bash\n' > "$pm"; printf '\n%s\ncommand -v staircase &>/dev/null && staircase doctor --fix >/dev/null 2>&1 || true\n# <<< stAirCase hooks <<<\n' "$guard" >> "$pm"; chmod +x "$pm"; _ok "post-merge hook for ${hn}"; fi; done; }
cmd_hooks() { local s="${1:-}"; shift || true; case "$s" in install) cmd_hooks_install "$@" ;; *) _err "Usage: staircase hooks install <v/p>"; exit 1 ;; esac; }

_usage() { cat >&2 << EOF
${_B}staircase${_Z} — AI workspace orchestrator v${VERSION}

Usage: staircase [--dry-run] <command> [args]

${_B}Workspace${_Z}
  init [--name <n>]                        Create workspace
  migrate                                  Migrate v1.1 workspace to v1.2
  config [<key>] [<value>]                 Get/set config
  config --list                            Show resolved config

${_B}Structure${_Z}
  vendor add|remove|list                   Manage vendors
  project add <v/p> [source-path]         Add project (optional symlink to source)
  project remove|list|info [--json]        Manage projects
  project link <v/p> <path>               Link / update source symlink
  project unlink <v/p>                    Remove source link
  component add|remove|list                Manage components

${_B}Cases${_Z}
  case new <v/p|v> <case-id>              Create case (project or vendor scope)
  case switch <v/p> <case-id>             Set last case (active context)
  case list [v[/p]] [--json]              List cases
  case info <v[/p]> <case-id>             Show case PRD as JSON
  case delete <v[/p]> <case-id>           Delete case

${_B}Agent${_Z}
  run <v/p|v> [case-id] [--runner <r>] [--config '{}']   Launch agent (uses lastCase if no id)

${_B}Inspection${_Z}
  ls [--json]                              Tree view
  status [--json]                          Table / JSON
  doctor [--fix]                           Health check
  export <v/p> [--format json|tar|langgraph]  Export cases

${_B}Hooks${_Z}
  hooks install <v/p>                      Install git hooks

${_B}Environment${_Z}
  STAIRCASE_DIR    STAIRCASE_TMP_DIR    STAIRCASE_HOOKS_DIR
  STAIRCASE_RUNNER STAIRCASE_DEBUG      NO_COLOR

EOF
}

main() { local args=(); for arg in "$@"; do case "$arg" in --dry-run) DRY_RUN=1 ;; --no-color) NO_COLOR=1; _R=''; _G=''; _Y=''; _C=''; _B=''; _D=''; _Z='' ;; --debug) export STAIRCASE_DEBUG=1 ;; --version) printf 'staircase %s\n' "$VERSION"; exit 0 ;; *) args+=("$arg") ;; esac; done; set -- "${args[@]+"${args[@]}"}"; [[ -n "${STAIRCASE_DEBUG:-}" ]] && set -x; local cmd="${1:-help}"; shift || true; case "$cmd" in init) cmd_init "$@" ;; migrate) cmd_migrate "$@" ;; config) cmd_config "$@" ;; vendor) cmd_vendor "$@" ;; project) cmd_project "$@" ;; component) cmd_component "$@" ;; case) cmd_case "$@" ;; run) cmd_run "$@" ;; ls) cmd_ls "$@" ;; status) cmd_status "$@" ;; doctor) cmd_doctor "$@" ;; export) cmd_export "$@" ;; hooks) cmd_hooks "$@" ;; help|--help|-h) _usage ;; *) _err "Unknown command: '${cmd}'"; _usage; exit 1 ;; esac; }

main "$@"
