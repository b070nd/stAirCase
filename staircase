_build_prd() { local ns="$1" v="$2" p="${3:-}" ws="$4"; local d; d="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; local cj="[]"; if [[ -n "$p" ]]; then cj="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components' "$ws/.staircase/manifest.json")"; fi; local scope="project"; [[ -z "$p" ]] && scope="vendor"; jq -n --arg id "$ns" --arg vendor "$v" --arg project "${p:-}" --arg scope "$scope" --arg created "$d" --arg modified "$d" --argjson components "$cj" '{id:$id,name:$id,vendor:$vendor,project:(if $project == "" then null else $project end),scope:$scope,components:$components,created:$created,modified:$modified,userStories:[],files:[],gitDiff:""}'; }

cmd_case_new() { local vp="${1:-}" id="${2:-}"; [[ -z "$vp" || -z "$id" ]] && { _err "Usage: staircase case new <v/p|v> <case-id>"; exit 1; }; SC_VENDOR=""; SC_PROJECT=""; _parse_vp_or_v "$vp"; local ws; ws="$(_require_ws)"; _require_jq; if [[ -n "$SC_PROJECT" ]]; then _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; fi; local ns; ns="$(_prd_ns "$SC_VENDOR" "$SC_PROJECT" "$id")"; local prd_path; prd_path="$(_prd_file "$ws" "$SC_VENDOR" "$SC_PROJECT" "$id")"; local prd_dir_target; prd_dir_target="$(dirname "$prd_path")"; mkdir -p "$prd_dir_target"; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] create case '${id}' (${ns})"; return 0; fi; local td; td="$(_tmp_dir "$ws")"; _build_prd "$ns" "$SC_VENDOR" "$SC_PROJECT" "$ws" | _atomic_write "$prd_path" "$td"; if [[ -n "$SC_PROJECT" ]]; then jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg lc "$id" '.vendors[$v].projects[$p].lastCase = $lc' "$ws/.staircase/manifest.json" | _atomic_write "$ws/.staircase/manifest.json" "$td"; fi; _ok "created case '${id}' (${ns})"; }
cmd_case_list() { local arg="" jf=0; for a in "$@"; do [[ "$a" == "--json" ]] && jf=1 || { [[ -z "$arg" ]] && arg="$a"; }; done; local ws; ws="$(_require_ws)"; _require_jq; local prd_dir; prd_dir="$(_prd_dir "$ws")"; [[ ! -d "$prd_dir" ]] && { _info "no cases"; return 0; }; local m="$ws/.staircase/manifest.json"; if [[ -z "$arg" ]]; then if [[ $jf -eq 1 ]]; then local ja="[]"; for f in "$prd_dir"/*/*/*.json "$prd_dir"/*/*.json; do [[ -f "$f" ]] || continue; local fid; fid="$(jq -r '.id // empty' "$f" 2>/dev/null)"; [[ -z "$fid" ]] && continue; local sc lm; sc="$(jq -r '.scope // "project"' "$f" 2>/dev/null)"; lm="$(_file_mtime "$f")"; ja="$(jq --arg id "$fid" --arg sc "$sc" --arg lm "$lm" '. += [{id:$id,scope:$sc,modified:$lm}]' <<< "$ja")"; done; printf '%s\n' "$ja"; return 0; fi; for f in "$prd_dir"/*/*/*.json "$prd_dir"/*/*.json; do [[ -f "$f" ]] || continue; local fid; fid="$(jq -r '.id // empty' "$f" 2>/dev/null)"; [[ -z "$fid" ]] && continue; local sc; sc="$(jq -r '.scope // "project"' "$f" 2>/dev/null)"; local lm; lm="$(_file_mtime "$f")"; printf "  %-40s  %-8s  %s\n" "$fid" "$sc" "$lm" >&2; done; return 0; fi; SC_VENDOR=""; SC_PROJECT=""; _parse_vp_or_v "$arg"; local lc=""; [[ -n "$SC_PROJECT" ]] && lc="$(_last_case "$ws" "$SC_VENDOR" "$SC_PROJECT")"; if [[ $jf -eq 1 ]]; then local ja="[]"; for f in "$prd_dir/$SC_VENDOR"/*.json "$prd_dir/$SC_VENDOR"/*/*.json; do [[ -f "$f" ]] || continue; local fid; fid="$(jq -r '.id // empty' "$f" 2>/dev/null)"; [[ -z "$fid" ]] && continue; local sc lm; sc="$(jq -r '.scope // "project"' "$f" 2>/dev/null)"; lm="$(_file_mtime "$f")"; ja="$(jq --arg id "$fid" --arg sc "$sc" --arg lm "$lm" '. += [{id:$id,scope:$sc,modified:$lm}]' <<< "$ja")"; done; printf '%s\n' "$ja"; return 0; fi; for f in "$prd_dir/$SC_VENDOR"/*.json "$prd_dir/$SC_VENDOR"/*/*.json; do [[ -f "$f" ]] || continue; local fid; fid="$(jq -r '.id // empty' "$f" 2>/dev/null)"; [[ -z "$fid" ]] && continue; local sc; sc="$(jq -r '.scope // "project"' "$f" 2>/dev/null)"; local lm; lm="$(_file_mtime "$f")"; local mk="  "; local case_part; case_part="${fid##*.}"; [[ -n "$lc" && "$case_part" == "$lc" ]] && mk="${_G}* ${_Z}"; printf "%b%-40s  %-8s  %s\n" "$mk" "$fid" "$sc" "$lm" >&2; done; }
cmd_case_info() { local vp="${1:-}" id="${2:-}"; [[ -z "$vp" || -z "$id" ]] && { _err "Usage: staircase case info <v[/p]> <case-id>"; exit 1; }; SC_VENDOR=""; SC_PROJECT=""; _parse_vp_or_v "$vp"; local ws; ws="$(_require_ws)"; _require_jq; local ns; ns="$(_prd_ns "$SC_VENDOR" "$SC_PROJECT" "$id")"; local prd_path; prd_path="$(_prd_file "$ws" "$SC_VENDOR" "$SC_PROJECT" "$id")"; [[ ! -f "$prd_path" ]] && { _err "case '${ns}' not found"; exit 1; }; jq '.' "$prd_path"; }
