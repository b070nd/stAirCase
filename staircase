set -euo pipefail

VERSION="1.3.0"

# ── Color helpers (all write to stderr) ────────────────────────────────────────
_R=''; _G=''; _Y=''; _C=''; _B=''; _D=''; _Z=''
if [[ -z "${NO_COLOR:-}" ]]; then
  _R=$'\033[0;31m'; _G=$'\033[0;32m'; _Y=$'\033[1;33m'
  _C=$'\033[0;36m'; _B=$'\033[1m';    _D=$'\033[0;90m'; _Z=$'\033[0m'
fi
_info() { printf "  %s→%s  %s\n" "$_C" "$_Z" "$*" >&2; }
_ok()   { printf "  %s✔%s  %s\n" "$_G" "$_Z" "$*" >&2; }
_warn() { printf "  %s⚠%s  %s\n" "$_Y" "$_Z" "$*" >&2; }
_err()  { printf "  %s✖%s  %s\n" "$_R" "$_Z" "$*" >&2; }

DRY_RUN="${DRY_RUN:-}"

_ws_root() {
  if [[ -n "${STAIRCASE_DIR:-}" ]]; then
    [[ -d "$STAIRCASE_DIR/.staircase" ]] && { printf '%s' "$STAIRCASE_DIR"; return 0; }
    return 1
  fi
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    [[ -d "$dir/.staircase" ]] && { printf '%s' "$dir"; return 0; }
    dir="$(dirname "$dir")"
  done
  return 1
}
_require_ws() { local ws; if ! ws="$(_ws_root)"; then _err "no workspace found — run: staircase init"; exit 1; fi; printf '%s' "$ws"; }
_require_jq() { if ! command -v jq &>/dev/null; then _err "jq is required — brew install jq"; exit 1; fi; }
_tmp_dir() { printf '%s' "${STAIRCASE_TMP_DIR:-$1/.staircase/tmp}"; }
_hooks_dir() { local ws="$1"; if [[ -n "${STAIRCASE_HOOKS_DIR:-}" ]]; then printf '%s' "$STAIRCASE_HOOKS_DIR"; else printf '%s' "$ws/$(jq -r '.hooks_dir // "hooks.d"' "$ws/.staircase/config.json" 2>/dev/null)"; fi; }
_runner() { local ws="$1" v="${2:-}" p="${3:-}" f="${4:-}"; [[ -n "$f" ]] && { printf '%s' "$f"; return; }; [[ -n "${STAIRCASE_RUNNER:-}" ]] && { printf '%s' "$STAIRCASE_RUNNER"; return; }; if [[ -n "$v" && -n "$p" ]]; then local pr; pr="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].runner // empty' "$ws/.staircase/manifest.json" 2>/dev/null)"; [[ -n "$pr" && "$pr" != "null" ]] && { printf '%s' "$pr"; return; }; fi; local wr; wr="$(jq -r '.runner // empty' "$ws/.staircase/config.json" 2>/dev/null)"; [[ -n "$wr" ]] && { printf '%s' "$wr"; return; }; printf '%s' "ralph-tui"; }
_file_mtime() { local f="$1" r; if r="$(date -r "$f" "+%Y-%m-%d %H:%M:%S" 2>/dev/null)"; then printf '%s' "$r"; elif r="$(stat -c "%y" "$f" 2>/dev/null)"; then printf '%s' "${r%%.*}"; else printf '%s' "-"; fi; }
_atomic_write() { local dest="$1" td="$2"; mkdir -p "$td"; local t; t="$(mktemp "$td/sc.XXXXXX")"; cat > "$t"; mv "$t" "$dest"; }
_parse_vp() { local vp="$1"; if [[ "$vp" != */* ]]; then _err "expected vendor/project, got: '$vp'"; exit 1; fi; SC_VENDOR="${vp%%/*}"; SC_PROJECT="${vp#*/}"; if [[ -z "$SC_VENDOR" || -z "$SC_PROJECT" || "$SC_PROJECT" == */* ]]; then _err "expected vendor/project, got: '$vp'"; exit 1; fi; }
_require_project() { local ws="$1" v="$2" p="$3"; local e; e="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p] // empty' "$ws/.staircase/manifest.json")"; if [[ -z "$e" ]]; then _err "'${v}/${p}' not registered — run: staircase project add ${v}/${p}"; exit 1; fi; }
_source_path() { local ws="$1" v="$2" p="$3"; jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].source // empty' "$ws/.staircase/manifest.json" 2>/dev/null || true; }
_prd_dir()   { printf '%s' "$1/.staircase/prd"; }
_prd_ns()    { local v="$1" p="${2:-}" id="$3"; [[ -n "$p" ]] && printf '%s.%s.%s' "$v" "$p" "$id" || printf '%s.%s' "$v" "$id"; }
_prd_file()  { local ws="$1" v="$2" p="${3:-}" id="$4"; [[ -n "$p" ]] && printf '%s' "$ws/.staircase/prd/$v/$p/$id.json" || printf '%s' "$ws/.staircase/prd/$v/$id.json"; }
_last_case() { local ws="$1" v="$2" p="$3"; jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].lastCase // empty' "$ws/.staircase/manifest.json" 2>/dev/null || true; }
_parse_vp_or_v() { local vp="$1"; if [[ "$vp" == */* ]]; then _parse_vp "$vp"; else [[ -z "$vp" ]] && { _err "expected vendor or vendor/project"; exit 1; }; SC_VENDOR="$vp"; SC_PROJECT=""; fi; }

cmd_init() { local ws_name=""; while [[ $# -gt 0 ]]; do case "$1" in --name) ws_name="${2:-}"; shift 2 ;; *) shift ;; esac; done; [[ -z "$ws_name" ]] && ws_name="$(basename "$PWD")"; local ws="$PWD"; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] create .staircase/"; [[ -f "$ws/.staircase/config.json" ]] && _ok "already initialized (no changes)"; return 0; fi; mkdir -p "$ws/.staircase/tmp" "$ws/.staircase/prd"; if [[ ! -f "$ws/.staircase/config.json" ]]; then _require_jq; jq -n --arg n "$ws_name" '{version:"1.2",name:$n,runner:"ralph-tui",hooks_dir:"hooks.d",defaults:{context_schema:{stories:[],files:[],gitDiff:""}}}' > "$ws/.staircase/config.json"; printf '{"version":"1.2","vendors":{}}\n' > "$ws/.staircase/manifest.json"; _ok "initialized workspace '${ws_name}'"; else _ok "already initialized"; fi; }

cmd_migrate() { local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json" td; td="$(_tmp_dir "$ws")"; _info "migrating workspace to v1.2..."; mkdir -p "$ws/.staircase/prd"; local vs; vs="$(jq -r '.vendors|keys[]' "$m" 2>/dev/null || true)"; while IFS= read -r v; do [[ -z "$v" ]] && continue; local ps; ps="$(jq -r --arg v "$v" '.vendors[$v].projects//{}|keys[]' "$m" 2>/dev/null || true)"; while IFS= read -r p; do [[ -z "$p" ]] && continue; local pd="$ws/$v/$p"; local old_sc="$pd/.staircase"; local proj_runner=""; [[ -f "$old_sc/config.json" ]] && proj_runner="$(jq -r '.runner // empty' "$old_sc/config.json" 2>/dev/null || true)"; local d; d="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; if [[ -d "$old_sc/tasks" ]]; then for td_dir in "$old_sc/tasks"/*/; do [[ -d "$td_dir" ]] || continue; local cid; cid="$(basename "$td_dir")"; local ctx="$td_dir/context.json"; [[ ! -f "$ctx" ]] && continue; local ns; ns="$(_prd_ns "$v" "$p" "$cid")"; local prd_out="$ws/.staircase/prd/${ns}.json"; local created; created="$(jq -r '.created // empty' "$ctx" 2>/dev/null || true)"; [[ -z "$created" ]] && created="$d"; local cj; cj="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components // []' "$m" 2>/dev/null || echo '[]')"; jq -n --arg id "$ns" --arg vendor "$v" --arg project "$p" --arg scope "project" --arg created "$created" --arg modified "$d" --argjson components "$cj" '{id:$id,name:$id,vendor:$vendor,project:$project,scope:$scope,components:$components,created:$created,modified:$modified,userStories:[],files:[],gitDiff:""}' > "$prd_out"; _ok "migrated case ${ns}"; done; fi; if [[ -f "$old_sc/active/context.json" ]]; then local act_id; act_id="$(jq -r '.caseId // empty' "$old_sc/active/context.json" 2>/dev/null || true)"; if [[ -n "$act_id" ]]; then local act_ns; act_ns="$(_prd_ns "$v" "$p" "$act_id")"; local act_prd="$ws/.staircase/prd/${act_ns}.json"; if [[ ! -f "$act_prd" ]]; then local created; created="$(jq -r '.created // empty' "$old_sc/active/context.json" 2>/dev/null || true)"; [[ -z "$created" ]] && created="$d"; local cj; cj="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components // []' "$m" 2>/dev/null || echo '[]')"; jq -n --arg id "$act_ns" --arg vendor "$v" --arg project "$p" --arg scope "project" --arg created "$created" --arg modified "$d" --argjson components "$cj" '{id:$id,name:$id,vendor:$vendor,project:$project,scope:$scope,components:$components,created:$created,modified:$modified,userStories:[],files:[],gitDiff:""}' > "$act_prd"; _ok "migrated active case ${act_ns}"; fi; fi; fi; local ac; ac="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].activeCase // empty' "$m" 2>/dev/null || true)"; local last_val="null"; [[ -n "$ac" && "$ac" != "null" ]] && last_val="\"$ac\""; if [[ -n "$proj_runner" && "$proj_runner" != "null" ]]; then m_tmp="$(jq --arg v "$v" --arg p "$p" --arg r "$proj_runner" --argjson lc "$last_val" 'del(.vendors[$v].projects[$p].activeCase) | .vendors[$v].projects[$p].runner = $r | .vendors[$v].projects[$p].lastCase = $lc' "$m")"; else m_tmp="$(jq --arg v "$v" --arg p "$p" --argjson lc "$last_val" 'del(.vendors[$v].projects[$p].activeCase) | .vendors[$v].projects[$p].runner = null | .vendors[$v].projects[$p].lastCase = $lc' "$m")"; fi; printf '%s\n' "$m_tmp" | _atomic_write "$m" "$td"; local sp; sp="$(_source_path "$ws" "$v" "$p")"; if [[ -n "$sp" && -d "$sp" ]]; then if [[ -d "$pd" && ! -L "$pd" ]]; then local contents; contents="$(ls -A "$pd" 2>/dev/null)"; if [[ -z "$contents" ]]; then rm -rf "$pd" && ln -s "$sp" "$pd" && _ok "converted ${v}/${p} to symlink → ${sp}" || _warn "could not convert ${v}/${p} to symlink"; else _warn "${v}/${p}: directory not empty — skipping symlink conversion (remove contents and re-run migrate)"; fi; elif [[ -L "$pd" ]]; then _ok "${v}/${p} is already a symlink"; fi; fi; if [[ -d "$pd/.staircase" ]]; then rm -rf "$pd/.staircase" && _ok "removed ${v}/${p}/.staircase/"; fi; done <<< "$ps"; done <<< "$vs"; local flat_found=0; for f in "$ws/.staircase/prd"/*.json; do [[ -f "$f" ]] || continue; flat_found=1; local fns fv fp fid dest; fns="$(basename "$f" .json)"; fv="$(jq -r '.vendor // empty' "$f" 2>/dev/null)"; fp="$(jq -r 'if .project == null then "" else .project end' "$f" 2>/dev/null)"; [[ -z "$fv" ]] && { _warn "skipping unreadable flat prd: $(basename "$f")"; continue; }; if [[ -n "$fp" ]]; then fid="${fns#${fv}.${fp}.}"; dest="$ws/.staircase/prd/$fv/$fp/$fid.json"; else fid="${fns#${fv}.}"; dest="$ws/.staircase/prd/$fv/$fid.json"; fi; mkdir -p "$(dirname "$dest")"; mv "$f" "$dest" && _ok "reorganised ${fns} → prd/${fv}/${fp:+${fp}/}${fid}.json"; done; [[ $flat_found -eq 0 ]] && _ok "prd layout already v1.3"; jq '.version = "1.3"' "$m" | _atomic_write "$m" "$td"; jq '.version = "1.3"' "$ws/.staircase/config.json" | _atomic_write "$ws/.staircase/config.json" "$td"; _ok "migration complete — workspace is now v1.3"; }

cmd_config() { local ws; ws="$(_require_ws)"; _require_jq; local key="${1:-}" val="${2:-}"; local cfg="$ws/.staircase/config.json"; if [[ "$key" == "--list" ]]; then printf "%s%-16s  %-20s  %s%s\n" "$_B" "KEY" "VALUE" "SOURCE" "$_Z" >&2; printf "%-16s  %-20s  %s\n" "----------------" "--------------------" "--------" >&2; local wr; wr="$(jq -r '.runner // "ralph-tui"' "$cfg")"; local rs="config"; [[ -n "${STAIRCASE_RUNNER:-}" ]] && { wr="$STAIRCASE_RUNNER"; rs="${_G}env${_Z}"; }; printf "%-16s  %-20s  %b\n" "runner" "$wr" "$rs" >&2; local hd; hd="$(jq -r '.hooks_dir // "hooks.d"' "$cfg")"; local hs="config"; [[ -n "${STAIRCASE_HOOKS_DIR:-}" ]] && { hd="$STAIRCASE_HOOKS_DIR"; hs="${_G}env${_Z}"; }; printf "%-16s  %-20s  %b\n" "hooks_dir" "$hd" "$hs" >&2; local td=".staircase/tmp" ts="default"; [[ -n "${STAIRCASE_TMP_DIR:-}" ]] && { td="$STAIRCASE_TMP_DIR"; ts="${_G}env${_Z}"; }; printf "%-16s  %-20s  %b\n" "tmp_dir" "$td" "$ts" >&2; printf "%-16s  %-20s  %s\n" "name" "$(jq -r '.name // "-"' "$cfg")" "config" >&2; return 0; fi; if [[ -z "$key" ]]; then jq '.' "$cfg"; return 0; fi; if [[ -z "$val" ]]; then jq -r --arg k "$key" '.[$k] // empty' "$cfg"; return 0; fi; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] config.$key = $val"; return 0; fi; local tmpd; tmpd="$(_tmp_dir "$ws")"; jq --arg k "$key" --arg v "$val" '.[$k] = $v' "$cfg" | _atomic_write "$cfg" "$tmpd"; _ok "config.$key = $val"; }

cmd_vendor_add() { local v="${1:-}"; [[ -z "$v" ]] && { _err "Usage: staircase vendor add <vendor>"; exit 1; }; local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json"; local e; e="$(jq -r --arg v "$v" '.vendors[$v] // empty' "$m")"; [[ -n "$e" ]] && { _err "vendor '${v}' already exists"; exit 1; }; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] add vendor '${v}'"; return 0; fi; mkdir -p "$ws/$v"; local td; td="$(_tmp_dir "$ws")"; local d; d="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; jq --arg v "$v" --arg d "$d" '.vendors[$v]={"registered_at":$d,"projects":{}}' "$m" | _atomic_write "$m" "$td"; _ok "added vendor '${v}'"; }
cmd_vendor_remove() { local v="${1:-}"; [[ -z "$v" ]] && { _err "Usage: staircase vendor remove <vendor>"; exit 1; }; local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json"; local pc; pc="$(jq -r --arg v "$v" '.vendors[$v].projects // {} | keys | length' "$m" 2>/dev/null)"; [[ "${pc:-0}" -gt 0 ]] && { _err "vendor '${v}' has projects — remove them first"; exit 1; }; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] remove vendor '${v}'"; return 0; fi; local td; td="$(_tmp_dir "$ws")"; jq --arg v "$v" 'del(.vendors[$v])' "$m" | _atomic_write "$m" "$td"; _ok "removed vendor '${v}'"; }
cmd_vendor_list() { local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json"; local vs; vs="$(jq -r '.vendors | keys[]' "$m" 2>/dev/null || true)"; [[ -z "$vs" ]] && { _info "no vendors"; return 0; }; while IFS= read -r v; do local pc; pc="$(jq -r --arg v "$v" '.vendors[$v].projects|keys|length' "$m")"; printf "  %s%s%s  %s(%s project%s)%s\n" "$_B" "$v" "$_Z" "$_D" "$pc" "$([[ "$pc" -eq 1 ]] && echo "" || echo "s")" "$_Z" >&2; done <<< "$vs"; }
cmd_vendor() { local s="${1:-}"; shift || true; case "$s" in add) cmd_vendor_add "$@" ;; remove) cmd_vendor_remove "$@" ;; list|ls) cmd_vendor_list "$@" ;; *) _err "Usage: staircase vendor <add|remove|list>"; exit 1 ;; esac; }

cmd_project_add() { local vp="${1:-}" src_arg="${2:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase project add <vendor/project> [source-path]"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json" td; td="$(_tmp_dir "$ws")"; local d; d="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; local e; e="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p] // empty' "$m" 2>/dev/null)"; [[ -n "$e" ]] && { _err "'${SC_VENDOR}/${SC_PROJECT}' already exists"; exit 1; }; local canon=""; if [[ -n "$src_arg" ]]; then if ! canon="$(cd "$src_arg" 2>/dev/null && pwd -P)"; then _err "path does not exist: '${src_arg}'"; exit 1; fi; fi; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] add project '${SC_VENDOR}/${SC_PROJECT}'"; return 0; fi; local ve; ve="$(jq -r --arg v "$SC_VENDOR" '.vendors[$v] // empty' "$m")"; if [[ -z "$ve" ]]; then mkdir -p "$ws/$SC_VENDOR"; jq --arg v "$SC_VENDOR" --arg d "$d" '.vendors[$v]={"registered_at":$d,"projects":{}}' "$m" | _atomic_write "$m" "$td"; _ok "auto-created vendor '${SC_VENDOR}'"; fi; if [[ -n "$canon" ]]; then ln -s "$canon" "$ws/$SC_VENDOR/$SC_PROJECT"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg d "$d" --arg s "$canon" '.vendors[$v].projects[$p]={"registered_at":$d,"components":[],"runner":null,"lastCase":null,"source":$s}' "$m" | _atomic_write "$m" "$td"; _ok "added project '${SC_VENDOR}/${SC_PROJECT}' → ${canon}"; else mkdir -p "$ws/$SC_VENDOR/$SC_PROJECT"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg d "$d" '.vendors[$v].projects[$p]={"registered_at":$d,"components":[],"runner":null,"lastCase":null}' "$m" | _atomic_write "$m" "$td"; _ok "added project '${SC_VENDOR}/${SC_PROJECT}'"; fi; }
cmd_project_remove() { local vp="${1:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase project remove <vendor/project>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] remove '${SC_VENDOR}/${SC_PROJECT}'"; return 0; fi; local td; td="$(_tmp_dir "$ws")"; local prd_dir; prd_dir="$(_prd_dir "$ws")"; for f in "$prd_dir/$SC_VENDOR/$SC_PROJECT"/*.json; do [[ -f "$f" ]] || continue; rm -f "$f"; done; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" 'del(.vendors[$v].projects[$p])' "$ws/.staircase/manifest.json" | _atomic_write "$ws/.staircase/manifest.json" "$td"; local pd="$ws/$SC_VENDOR/$SC_PROJECT"; if [[ -L "$pd" ]]; then rm -f "$pd"; _ok "removed symlink '${SC_VENDOR}/${SC_PROJECT}'"; elif [[ -d "$pd" ]]; then rm -rf "$pd"; _ok "removed directory '${SC_VENDOR}/${SC_PROJECT}'"; fi; _ok "removed '${SC_VENDOR}/${SC_PROJECT}' from manifest"; }
cmd_project_list() { local fv="${1:-}"; local ws; ws="$(_require_ws)"; _require_jq; local m="$ws/.staircase/manifest.json"; local vs; [[ -n "$fv" ]] && vs="$fv" || vs="$(jq -r '.vendors|keys[]' "$m" 2>/dev/null || true)"; [[ -z "$vs" ]] && { _info "no projects"; return 0; }; while IFS= read -r v; do [[ -z "$v" ]] && continue; local ps; ps="$(jq -r --arg v "$v" '.vendors[$v].projects//{}|keys[]' "$m" 2>/dev/null || true)"; while IFS= read -r p; do [[ -z "$p" ]] && continue; local lc; lc="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].lastCase // "(none)"' "$m")"; [[ "$lc" == "null" ]] && lc="(none)"; local cc; cc="$(jq -r --arg v "$v" --arg p "$p" '.vendors[$v].projects[$p].components|length' "$m")"; printf "  %s%s/%s%s  last: %s  components: %s\n" "$_B" "$v" "$p" "$_Z" "$lc" "$cc" >&2; done <<< "$ps"; done <<< "$vs"; }
cmd_project_info() { local vp="" jf=0; for a in "$@"; do [[ "$a" == "--json" ]] && jf=1 || { [[ -z "$vp" ]] && vp="$a"; }; done; [[ -z "$vp" ]] && { _err "Usage: staircase project info <vendor/project>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local m="$ws/.staircase/manifest.json"; printf "\n  %s%s/%s%s\n\n" "$_B" "$SC_VENDOR" "$SC_PROJECT" "$_Z" >&2; local lc; lc="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p].lastCase // "(none)"' "$m")"; [[ "$lc" == "null" ]] && lc="(none)"; local sp; sp="$(_source_path "$ws" "$SC_VENDOR" "$SC_PROJECT")"; if [[ -n "$sp" ]]; then printf "  source:       %s\n" "$sp" >&2; else printf "  source:       %s(not linked)%s\n" "$_D" "$_Z" >&2; fi; printf "  last case:    %s\n" "$lc" >&2; printf "  runner:       %s\n" "$(_runner "$ws" "$SC_VENDOR" "$SC_PROJECT" "")" >&2; local prd_dir; prd_dir="$(_prd_dir "$ws")"; local cases_count=0; for f in "$prd_dir/$SC_VENDOR/$SC_PROJECT"/*.json; do [[ -f "$f" ]] || continue; cases_count=$((cases_count+1)); done; printf "  cases:        %s\n" "$cases_count" >&2; local cs; cs="$(jq -r --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p].components[]' "$m" 2>/dev/null || true)"; if [[ $jf -eq 1 ]]; then jq -n --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg lc "$lc" --arg sp "${sp:-}" --arg runner "$(_runner "$ws" "$SC_VENDOR" "$SC_PROJECT" "")" --argjson cases "$cases_count" --argjson components "$(jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" '.vendors[$v].projects[$p].components // []' "$m")" '{vendor:$v,project:$p,source:(if $sp=="" then null else $sp end),lastCase:(if $lc=="(none)" then null else $lc end),runner:$runner,cases:$cases,components:$components}'; return 0; fi; if [[ -z "$cs" ]]; then printf "  components:   (none)\n" >&2; else printf "  components:\n" >&2; while IFS= read -r c; do printf "    - %s\n" "$c" >&2; done <<< "$cs"; fi; printf "\n" >&2; }
cmd_project_link() { local vp="${1:-}" src="${2:-}"; [[ -z "$vp" || -z "$src" ]] && { _err "Usage: staircase project link <v/p> <path>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local canon; if ! canon="$(cd "$src" 2>/dev/null && pwd -P)"; then _err "path does not exist: '${src}'"; exit 1; fi; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] link ${SC_VENDOR}/${SC_PROJECT} → ${canon}"; return 0; fi; local m="$ws/.staircase/manifest.json" td; td="$(_tmp_dir "$ws")"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg s "$canon" '.vendors[$v].projects[$p].source = $s' "$m" | _atomic_write "$m" "$td"; local pd="$ws/$SC_VENDOR/$SC_PROJECT"; if [[ -L "$pd" ]]; then rm -f "$pd" && ln -s "$canon" "$pd"; elif [[ -d "$pd" ]]; then local contents; contents="$(ls -A "$pd" 2>/dev/null)"; if [[ -z "$contents" ]]; then rm -rf "$pd"; ln -s "$canon" "$pd"; else _warn "${SC_VENDOR}/${SC_PROJECT} has contents — updated manifest only, directory unchanged"; fi; else ln -s "$canon" "$pd"; fi; _ok "linked ${SC_VENDOR}/${SC_PROJECT} → ${canon}"; }
cmd_project_unlink() { local vp="${1:-}"; [[ -z "$vp" ]] && { _err "Usage: staircase project unlink <v/p>"; exit 1; }; _parse_vp "$vp"; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] unlink ${SC_VENDOR}/${SC_PROJECT}"; return 0; fi; local m="$ws/.staircase/manifest.json" td; td="$(_tmp_dir "$ws")"; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" 'del(.vendors[$v].projects[$p].source)' "$m" | _atomic_write "$m" "$td"; local pd="$ws/$SC_VENDOR/$SC_PROJECT"; if [[ -L "$pd" ]]; then rm -f "$pd"; mkdir -p "$pd"; fi; _ok "unlinked ${SC_VENDOR}/${SC_PROJECT}"; }
