cmd_component_add() { local vp="${1:-}"; shift || true; [[ -z "$vp" ]] && { _err "Usage: staircase component add <v/p> <comp> [...]"; exit 1; }; _parse_vp "$vp"; [[ $# -eq 0 ]] && { _err "Usage: staircase component add <v/p> <comp> [...]"; exit 1; }; local ws; ws="$(_require_ws)"; _require_jq; _require_project "$ws" "$SC_VENDOR" "$SC_PROJECT"; local m="$ws/.staircase/manifest.json" td; td="$(_tmp_dir "$ws")"; local c; for c in "$@"; do if [[ -n "$DRY_RUN" ]]; then _info "[DRY RUN] add component '${c}'"; continue; fi; local pd="$ws/$SC_VENDOR/$SC_PROJECT"; if [[ ! -L "$pd" ]]; then mkdir -p "$pd/$c"; fi; jq --arg v "$SC_VENDOR" --arg p "$SC_PROJECT" --arg c "$c" 'if(.vendors[$v].projects[$p].components|index($c))then . else .vendors[$v].projects[$p].components+=[$c] end' "$m" | _atomic_write "$m" "$td"; _ok "added component '${c}' to ${SC_VENDOR}/${SC_PROJECT}"; done; }
